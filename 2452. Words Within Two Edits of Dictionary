class Solution {
public:
    vector<string> twoEditWords(vector<string>& queries, vector<string>& dictionary) {
        vector<string> answer;

        for (auto ele : queries) {
            for (auto word : dictionary) {
                
                int diff = 0;

                for (int i = 0; i < ele.size(); i++) {
                    if (ele[i] != word[i]) {
                        diff++;
                    }
                    if (diff > 2) break;
                }

                if (diff <= 2) {
                    answer.push_back(ele);
                    break;
                }
            }
        }

        return answer;
    }
};
