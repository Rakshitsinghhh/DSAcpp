class Solution {
public:
    bool carPooling(vector<vector<int>>& trips, int capacity) {
        vector<int> trip(1001, 0);

        for (auto ele : trips) {
            trip[ele[1]] += ele[0];
            trip[ele[2]] -= ele[0];
        }

        int passengers = 0;

        for (int i = 0; i <= 1000; i++) {
            passengers += trip[i];

            if (passengers > capacity)
                return false;
        }

        return true;
    }
};
