class Solution {
public:
    vector<vector<char>> rotateTheBox(vector<vector<char>>& boxGrid) {

        int m = boxGrid.size();
        int n = boxGrid[0].size();

        vector<vector<char>> rboxGrid(n, vector<char>(m));

        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){
                rboxGrid[j][i] = boxGrid[i][j];
            }
        }

        for(int i = 0; i < n; i++){
            reverse(rboxGrid[i].begin(), rboxGrid[i].end());
        }

        for(int j = 0; j < m; j++){
            for(int i = n - 1; i >= 0; i--){
                if(rboxGrid[i][j] == '.'){
                    int k = i - 1;
                    while(k >= 0 && rboxGrid[k][j] == '.') k--;

                    if(k >= 0 && rboxGrid[k][j] == '#'){
                        swap(rboxGrid[i][j], rboxGrid[k][j]);
                    }
                }
            }
        }

        return rboxGrid;
    }
};
