class Solution {
public:
    vector<int> corpFlightBookings(vector<vector<int>>& bookings, int n) {
        vector<int> seen(n + 1, 0);

        for (auto ele : bookings) {
            seen[ele[0] - 1] += ele[2];
            
            if (ele[1] < n)
                seen[ele[1]] -= ele[2];
        }

        for (int i = 1; i < n; i++) {
            seen[i] += seen[i - 1];
        }

        seen.pop_back();   // Remove the extra element

        return seen;
    }
};
