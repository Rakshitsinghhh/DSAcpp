class Solution {
public:
    vector<int> getBiggestThree(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();

        set<int> sums;

        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){

                sums.insert(grid[i][j]);

                for(int k = 1; i + 2*k < m && j-k >= 0 && j+k < n; k++){

                    int sum = 0;

                    int x = i;
                    int y = j;

                    for(int d=0; d<k; d++) sum += grid[x+d][y-d];
                    for(int d=0; d<k; d++) sum += grid[x+k+d][y-k+d];
                    for(int d=0; d<k; d++) sum += grid[x+2*k-d][y+d];
                    for(int d=0; d<k; d++) sum += grid[x+k-d][y+k-d];

                    sums.insert(sum);
                }
            }
        }

        vector<int> ans;
        for(auto it = sums.rbegin(); it != sums.rend() && ans.size()<3; it++)
            ans.push_back(*it);

        return ans;
    }
};
