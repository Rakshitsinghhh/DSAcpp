class Solution {
public:
    int leastBricks(vector<vector<int>>& wall) {
        int m = 0;
        unordered_map<int,int> seen;

        for(int i = 0; i < wall.size(); i++){
            long long sum = 0;
            for(int j = 0; j < wall[i].size() - 1; j++){
                sum += wall[i][j];
                seen[sum]++;
                m = max(m, seen[sum]);
            }
        }

        return wall.size() - m;
    }
};
