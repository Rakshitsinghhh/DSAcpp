class Solution {
public:
    int dfs(vector<vector<int>>& grid,int i,int j){
        int m = grid.size(), n = grid[0].size();

        if(i < 0 || j < 0 || i >= m || j >= n){
            return 1;
        }

        if(grid[i][j] == 0){
            return 1;
        }

        if(grid[i][j] == -1){
            return 0;
        }

        grid[i][j] = -1;
        int peri = 0;

        peri += dfs(grid, i+1, j);
        peri += dfs(grid, i-1, j);
        peri += dfs(grid, i, j+1);
        peri += dfs(grid, i, j-1);

        return peri;
    }

    int islandPerimeter(vector<vector<int>>& grid) {
        for(int i = 0; i < grid.size(); i++){
            for(int j = 0; j < grid[0].size(); j++){
                if(grid[i][j] == 1){
                    return dfs(grid, i, j);
                }
            }
        }
        return 0;
    }
};
