class Solution {
public:
    bool canPartitionGrid(vector<vector<int>>& grid) {
        int r = grid.size();
        int c = grid[0].size();

        long long total = 0;

        for(int i = 0; i < r; i++) {
            for(int j = 0; j < c; j++) {
                total += grid[i][j];
            }
        }

        long long horizontal = 0;
        for(int i = 0; i < r - 1; i++) {
            for(int j = 0; j < c; j++) {
                horizontal += grid[i][j];
            }
            if(horizontal * 2 == total) return true;
        }

        long long vertical = 0;
        for(int j = 0; j < c - 1; j++) {
            for(int i = 0; i < r; i++) {
                vertical += grid[i][j];
            }
            if(vertical * 2 == total) return true;
        }

        return false;
    }
};
